POSTGRES_DB=logitrack
POSTGRES_USER=logitrack
POSTGRES_PASSWORD=change-this-database-password

BACKEND_PORT=18080
FRONTEND_PORT=3001
SPRING_PROFILES_ACTIVE=demo
TZ=America/Sao_Paulo

# Gere um valor aleatório com pelo menos 32 bytes antes de publicar o sistema.
LOGITRACK_JWT_SECRET=replace-with-a-long-random-secret-of-at-least-32-bytes
LOGITRACK_JWT_EXPIRATION_MS=28800000
LOGITRACK_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

LOGITRACK_LOGIN_MAX_ATTEMPTS=5
LOGITRACK_LOGIN_WINDOW_SECONDS=900
